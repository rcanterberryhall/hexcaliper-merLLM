# Normalize line endings so a Windows checkout never corrupts files that are
# executed inside the Linux container. Without this, core.autocrlf=true (the
# Windows default) rewrites shell scripts to CRLF on checkout; the container's
# kernel then reads the shebang as `#!/bin/sh\r`, fails to exec the interpreter,
# and the ENTRYPOINT dies with exit code 255.
# Origin of this fix: hexcaliper-scrivener commit afe41f6.

# Default: let git decide text vs binary, but always check out text as LF.
* text=auto eol=lf

# Files run by /bin/sh inside the container — MUST stay LF on every platform.
*.sh            text eol=lf
Dockerfile      text eol=lf
*.dockerfile    text eol=lf

# Other text that should stay LF for the Linux image / tooling.
*.py            text eol=lf
*.toml          text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.json          text eol=lf
*.md            text eol=lf

# Binary assets — never touch these.
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.pdf           binary
*.ico           binary
